// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

// 1. ตั้งค่าการเชื่อมต่อฐานข้อมูล (PostgreSQL)
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 2. ตั้งค่าตัวเจนโค้ดสำหรับฝั่ง Node.js
generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native","debian-openssl-3.0.x"]
}

// 3. กำหนดสิทธิ์ผู้ใช้งาน (Enum Roles)
enum UserRole {
  Admin
  Operator
}

// 4. ตารางผู้ใช้งาน (Users)
model User {
  id           Int        @id @default(autoincrement())
  username     String     @unique
  passwordHash String     // 🌟 เอา @map ออกแล้ว
  firstName    String     
  lastName     String?    
  role         UserRole   @default(Operator)
  isActive     Boolean    @default(true) 
  createdAt    DateTime   @default(now()) 
  updatedAt    DateTime   @updatedAt 
  
  // Relation: ผู้ใช้งาน 1 คน สามารถมีประวัติการแพ็คได้หลายรายการ
  packingLogs  PackingLog[]

  @@map("users") // ชื่อตารางยังคงเป็น users เหมือนเดิม
}

// 5. ตารางฐานข้อมูลกล่องบรรจุภัณฑ์ (Boxes Master Data)
model Box {
  pckId        String   @id // รหัสกล่อง เช่น 'PCK0000022'
  description  String
  maxCapacity  Int      
  width        Float?
  length       Float?
  height       Float?
  boxWeight    Float    @default(0.0) 
  desiccantQty Int      @default(0) 
  currentStock Int      @default(0) 
  createdAt    DateTime @default(now()) 
  updatedAt    DateTime @updatedAt 
  minStockLevel Int     @default(0) // จุดแจ้งเตือนสั่งซื้อ (ถ้าสต็อกต่ำกว่านี้จะแจ้งเตือน)
  
  // Relation: กล่อง 1 ไซส์ สามารถถูกผูกเป็นกล่องมาตรฐานให้กับสินค้าได้หลายชิ้น
  items        Item[]

  @@map("boxes")
}

// 6. ตารางฐานข้อมูลสินค้า (Items Master Data)
model Item {
  itemId         String   @id // รหัสสินค้า
  itemName       String   
  supplier       String
  itemWeight     Float    
  defaultPckId   String?  
  stdPackQty     Int      @default(1)
  boxesPerUnit Int      @default(1)
  createdAt      DateTime @default(now()) 
  updatedAt      DateTime @updatedAt 
 
  
  // Relation Link: เชื่อมไปหาตารางกล่องบรรจุภัณฑ์
  defaultBox     Box?     @relation(fields: [defaultPckId], references: [pckId], onDelete: SetNull)
  
  // Relation: สินค้า 1 ชิ้น สามารถมีประวัติการถูกแพ็คได้หลายครั้ง
  packingLogs    PackingLog[]

  @@map("items")
}

// 7. ตารางบันทึกประวัติการแพ็คจริงหน้างาน (Packing Logs Transaction)
model PackingLog {
  logId       BigInt   @id @default(autoincrement()) 
  packedAt    DateTime @default(now()) 
  userId      Int      
  itemId      String   
  packQty     Int      
  boxUsed     Float    // รองรับจำนวนกล่องแบบทศนิยม เช่น 1.5
  totalWeight Float    

  // Relation Links: เชื่อมโยงประวัติกลับไปหาคนแพ็คและตัวสินค้า
  user        User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  item        Item     @relation(fields: [itemId], references: [itemId], onDelete: Restrict)

  @@index([packedAt]) // ทำ Index ที่เวลาเพื่อความเร็วในการ Query รายงานย้อนหลัง
  @@map("packing_logs")
}

model Report {
  id          Int      @id @default(autoincrement())
  createdAt   DateTime @default(now()) // วันที่และเวลาที่บันทึก
  operator    String   // ชื่อพนักงานที่กดบันทึก
  totalOrders Int      // จำนวนรายการสินค้าในรอบนั้น
  totalBoxes  Int      // จำนวนกล่องรวมที่ต้องใช้ในรอบนั้น
  data        String   // เก็บข้อมูลตารางรายก้อน (แปลงเป็น JSON String)
}